---
import { site, nav } from "../data/site";

const { lang = "en" } = Astro.props as { lang?: "en" | "th" };
const menu = nav[lang];

const footerText = {
  en: {
    label: "Contemporary Art / Personal Gallery",
    inquiry: "Artwork inquiries, exhibitions, and collaborations.",
    contact: "Contact",
    location: site.location.en,
  },
  th: {
    label: "ศิลปะร่วมสมัย / แกลเลอรีส่วนตัว",
    inquiry: "สอบถามผลงาน นิทรรศการ และการร่วมงาน",
    contact: "ติดต่อ",
    location: site.location.th,
  },
};

const t = footerText[lang];
---

<footer class="bg-black text-white">
  <section class="mx-auto max-w-7xl px-5 py-16 md:px-8 md:py-24">
    <div class="grid gap-12 border-b border-white/10 pb-14 md:grid-cols-[1.15fr_0.85fr]">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-white/40">
          {t.label}
        </p>

        <h2 class="serif max-w-3xl text-5xl leading-[0.95] md:text-6xl first-letter:text-[1.13em] first-letter:mr-[1px]">
          PhanatchaNuch
        </h2>

        <p class="mt-8 max-w-md text-sm leading-8 text-white/55">
          {t.inquiry}
        </p>

        <a
          href={`/${lang}/contact`}
          class="mt-10 inline-flex border-b border-white pb-2 text-xs uppercase tracking-[0.2em] text-white transition hover:text-white/70"
        >
          {t.contact} →
        </a>
      </div>

      <div class="grid gap-10 lg:grid-cols-3 md:justify-self-end">
        <div>
          <p class="mb-5 text-xs uppercase tracking-[0.24em] text-white/35">
            Navigation
          </p>

          <nav class="flex flex-col gap-4 text-sm text-white/60">
            {menu.map((item: { href: string | URL | null | undefined; label: unknown; }) => (
              <a href={item.href} class="transition hover:text-white">
                {item.label}
              </a>
            ))}
          </nav>
        </div>

        <div>
          <p class="mb-5 text-xs uppercase tracking-[0.24em] text-white/35">
            Studio
          </p>

          <div class="space-y-4 text-sm text-white/60">
            <p class="mt-8 max-w-md text-\[11px\] leading-8 text-white/55">{t.location}</p>
            <p class="mt-8 max-w-md text-\[11px\] leading-8 text-white/55">{site.email}</p>
            <p class="mt-8 max-w-md text-\[11px\] leading-8 text-white/55">@{site.instagram}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-between gap-5 pt-8 text-xs uppercase tracking-[0.16em] text-white/35 md:flex-row">
      <p>© 2026 {site.name}. All rights reserved.</p>
      <p>Minimal artist portfolio / responsive website</p>
    </div>
  </section>
</footer>