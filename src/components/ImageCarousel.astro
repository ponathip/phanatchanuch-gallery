---
const { images = [], title = "Artwork image" } = Astro.props;
const safeImages = images.length ? images : [];
---

<div class="image-carousel" data-carousel>
  <div class="relative overflow-hidden bg-black/5">
    <img
      data-carousel-main
      src={safeImages[0]}
      alt={title}
      class="h-[420px] w-full object-cover md:h-[720px]"
      loading="eager"
    />

    <button
      type="button"
      data-carousel-prev
      class="absolute left-0 top-1/2 flex h-14 w-12 -translate-y-1/2 items-center justify-center bg-white/90 text-2xl"
      aria-label="Previous image"
    >
      ‹
    </button>

    <button
      type="button"
      data-carousel-next
      class="absolute right-0 top-1/2 flex h-14 w-12 -translate-y-1/2 items-center justify-center bg-white/90 text-2xl"
      aria-label="Next image"
    >
      ›
    </button>

    <button
      type="button"
      data-lightbox-open
      class="absolute right-5 top-5 bg-white/90 px-4 py-3 text-xs uppercase tracking-[0.18em]"
    >
      Zoom
    </button>
  </div>

  <div class="mt-5 flex gap-3 overflow-x-auto pb-2">
    {safeImages.map((image, index) => (
      <button
        type="button"
        data-carousel-thumb
        data-index={index}
        class:list={[
          "h-24 w-24 shrink-0 overflow-hidden border bg-black/5 md:h-32 md:w-32",
          index === 0 ? "border-black" : "border-transparent",
        ]}
      >
        <img
          src={image}
          alt={`${title} ${index + 1}`}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </button>
    ))}
  </div>

  <div class="mt-4 flex items-center justify-center gap-2">
    {safeImages.map((_, index) => (
      <span
        data-carousel-dot
        data-index={index}
        class:list={[
          "h-1.5 w-1.5 rounded-full",
          index === 0 ? "bg-black" : "bg-black/20",
        ]}
      ></span>
    ))}
  </div>

  <p class="mt-4 text-center text-xs uppercase tracking-[0.18em] text-black/45">
    <span data-carousel-count>1</span> / {safeImages.length}
  </p>

  <div
    data-lightbox
    class="fixed inset-0 z-[100] hidden bg-black/95 p-5"
  >
    <button
      type="button"
      data-lightbox-close
      class="absolute right-5 top-5 text-xs uppercase tracking-[0.2em] text-white/70"
    >
      Close
    </button>

    <div class="flex h-full items-center justify-center">
      <img
        data-lightbox-image
        src={safeImages[0]}
        alt={title}
        class="max-h-full max-w-full object-contain"
      />
    </div>
  </div>
</div>

<script>
  document.querySelectorAll("[data-carousel]").forEach((carousel) => {
    const images = Array.from(
      carousel.querySelectorAll("[data-carousel-thumb] img")
    ).map((img) => img.getAttribute("src"));

    let current = 0;

    const main = carousel.querySelector("[data-carousel-main]");
    const count = carousel.querySelector("[data-carousel-count]");
    const thumbs = carousel.querySelectorAll("[data-carousel-thumb]");
    const dots = carousel.querySelectorAll("[data-carousel-dot]");
    const lightbox = carousel.querySelector("[data-lightbox]");
    const lightboxImage = carousel.querySelector("[data-lightbox-image]");

    const update = (index) => {
      current = (index + images.length) % images.length;

      main.src = images[current];
      lightboxImage.src = images[current];

      count.textContent = String(current + 1);

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle("border-black", i === current);
        thumb.classList.toggle("border-transparent", i !== current);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-black", i === current);
        dot.classList.toggle("bg-black/20", i !== current);
      });
    };

    carousel
      .querySelector("[data-carousel-prev]")
      ?.addEventListener("click", () => update(current - 1));

    carousel
      .querySelector("[data-carousel-next]")
      ?.addEventListener("click", () => update(current + 1));

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        update(Number(thumb.getAttribute("data-index")));
      });
    });

    carousel
      .querySelector("[data-lightbox-open]")
      ?.addEventListener("click", () => {
        lightbox.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      });

    carousel
      .querySelector("[data-lightbox-close]")
      ?.addEventListener("click", () => {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
      });

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
      }
    });
  });
</script>