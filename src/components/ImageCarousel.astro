---
const { images = [], title = "Artwork image" } = Astro.props;
const safeImages = images.length ? images : [];
---

<div class="image-carousel w-full min-w-0 overflow-hidden" data-carousel>
  <div class="relative flex w-full min-w-0 items-center justify-center overflow-hidden bg-black/5">
    <img
      data-carousel-main
      src={safeImages[0]}
      alt={title}
      class="block h-auto max-h-[70vh] w-full max-w-full object-contain bg-white md:max-h-[620px]"
      loading="eager"
    />

    <button
      type="button"
      data-carousel-prev
      class="absolute
    left-3
    top-1/2
    z-10
    flex
    h-11
    w-11
    -translate-y-1/2
    items-center
    justify-center
    rounded-full
    bg-black/65
    text-2xl
    text-white
    shadow-xl
    backdrop-blur-sm
    transition
    hover:bg-black/85"
      aria-label="Previous image"
    >
      ‹
    </button>

    <button
      type="button"
      data-carousel-next
      class="absolute
    right-3
    top-1/2
    z-10
    flex
    h-11
    w-11
    -translate-y-1/2
    items-center
    justify-center
    rounded-full
    bg-black/65
    text-2xl
    text-white
    shadow-xl
    backdrop-blur-sm
    transition
    hover:bg-black/85"
      aria-label="Next image"
    >
      ›
    </button>

    <button
      type="button"
      data-lightbox-open
      class="absolute right-5 top-5 bg-white/90 px-4 py-3 text-xs uppercase tracking-[0.18em]"
    >
      Zoom
    </button>
  </div>

  <div class="mt-5 w-full max-w-full min-w-0 overflow-x-auto overscroll-x-contain pb-2">
    <div class="flex w-max gap-3">
    {
      safeImages.map((image, index) => (
        <button
          type="button"
          data-carousel-thumb
          data-index={index}
          class:list={[
            "h-20 w-20 shrink-0 overflow-hidden border bg-black/5 sm:h-24 sm:w-24 md:h-32 md:w-32",
            index === 0 ? "border-black" : "border-transparent",
          ]}
        >
          <img
            src={image}
            alt={`${title} ${index + 1}`}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        </button>
      ))
    }
    </div>
  </div>

  <div class="mt-4 flex items-center justify-center gap-2">
    {
      safeImages.map((_, index) => (
        <span
          data-carousel-dot
          data-index={index}
          class:list={[
            "h-1.5 w-1.5 rounded-full",
            index === 0 ? "bg-black" : "bg-black/20",
          ]}
        />
      ))
    }
  </div>

  <p class="mt-4 text-center text-xs uppercase tracking-[0.18em] text-black/45">
    <span data-carousel-count>1</span> / {safeImages.length}
  </p>

<div
  data-lightbox
  class="fixed inset-0 z-[2147483647] hidden bg-black/95 px-4 py-10"
>
  <button
    type="button"
    data-lightbox-close
    class="fixed right-6 top-6 z-[2147483647] flex h-12 w-12 items-center justify-center rounded-full bg-white text-3xl leading-none text-black shadow-lg"
    aria-label="Close image viewer"
  >
    ×
  </button>

  <button
    type="button"
    data-lightbox-prev
    class="fixed left-4 top-1/2 z-[2147483647] flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-3xl shadow"
  >
    ‹
  </button>
  <button
  type="button"
  data-lightbox-next
  class="fixed right-4 top-1/2 z-[2147483647] flex h-12 w-12 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-3xl shadow"
>
  ›
</button>
  <div class="flex h-full w-full items-center justify-center">
    <img
      data-lightbox-image
      src={safeImages[0]}
      alt={title}
      class="max-h-[88vh] max-w-[92vw] object-contain"
    />
  </div>
</div>
</div>

<script>
  document.querySelectorAll("[data-carousel]").forEach((carousel) => {
    const images = Array.from(
      carousel.querySelectorAll("[data-carousel-thumb] img"),
    ).map((img) => img.getAttribute("src"));

    let current = 0;

    const main = carousel.querySelector("[data-carousel-main]");
    const count = carousel.querySelector("[data-carousel-count]");
    const thumbs = carousel.querySelectorAll("[data-carousel-thumb]");
    const dots = carousel.querySelectorAll("[data-carousel-dot]");
    const lightbox = carousel.querySelector("[data-lightbox]");
    const lightboxImage = carousel.querySelector("[data-lightbox-image]");
    const lightboxPrev = carousel.querySelector("[data-lightbox-prev]");
    const lightboxNext = carousel.querySelector("[data-lightbox-next]");

    const update = (index) => {
      current = (index + images.length) % images.length;

      main.src = images[current];
      lightboxImage.src = images[current];

      count.textContent = String(current + 1);

      thumbs.forEach((thumb, i) => {
        thumb.classList.toggle("border-black", i === current);
        thumb.classList.toggle("border-transparent", i !== current);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-black", i === current);
        dot.classList.toggle("bg-black/20", i !== current);
      });
    };

    carousel
      .querySelector("[data-carousel-prev]")
      ?.addEventListener("click", () => update(current - 1));

    carousel
      .querySelector("[data-carousel-next]")
      ?.addEventListener("click", () => update(current + 1));

    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        update(Number(thumb.getAttribute("data-index")));
      });
    });

    carousel
      .querySelector("[data-lightbox-open]")
      ?.addEventListener("click", () => {
        document.body.appendChild(lightbox);
        lightbox.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      });

    carousel
      .querySelector("[data-lightbox-close]")
      ?.addEventListener("click", () => {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
      });

    lightbox?.addEventListener("click", (event) => {
      if (event.target === lightbox) {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
      }
    });

    lightboxImage?.addEventListener("click", (event) => {
      event.stopPropagation();
    });

    document.addEventListener("keydown", (event) => {
      if (lightbox?.classList.contains("hidden")) return;

      if (event.key === "ArrowLeft") update(current - 1);
      if (event.key === "ArrowRight") update(current + 1);

      if (event.key === "Escape") {
        lightbox.classList.add("hidden");
        document.body.style.overflow = "";
      }
    });

    lightboxPrev?.addEventListener("click", (event) => {
      event.stopPropagation();
      update(current - 1);
    });

    lightboxNext?.addEventListener("click", (event) => {
      event.stopPropagation();
      update(current + 1);
    });
  });
</script>
