---
const {
  slug,
  type = "artwork",
  viewCount = 0,
  likeCount = 0,
  lang = "en",
} = Astro.props;

const isTH = lang === "th";
---

<div
  class="flex items-center gap-6 border-b border-black/10 py-6 text-sm text-black/50"
  data-artwork-stats
  data-slug={slug}
  data-type={type}
>
  <span class="inline-flex items-center gap-2">
    <span class="text-base">👁</span>
    <span data-view-count>{viewCount}</span>
    <span>{isTH ? "เข้าชม" : "views"}</span>
  </span>

  <button
    type="button"
    class="inline-flex items-center gap-2 transition hover:text-black"
    data-like-button
  >
    <span data-like-icon>♡</span>
    <span data-like-count>{likeCount}</span>
    <span>{isTH ? "ถูกใจ" : "likes"}</span>
  </button>
</div>
<script define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL }}>
  
  document.querySelectorAll("[data-artwork-stats]").forEach((el) => {
    const slug = el.getAttribute("data-slug");
    const likeButton = el.querySelector("[data-like-button]");
    const likeIcon = el.querySelector("[data-like-icon]");
    const likeCountEl = el.querySelector("[data-like-count]");
    const viewCountEl = el.querySelector("[data-view-count]");
    const type = el.getAttribute("data-type") || "artwork";
    if (!slug) return;

    const likedKey = `liked:${slug}`;
    const viewedKey = `viewed:${slug}`;

    if (localStorage.getItem(likedKey) === "true") {
      likeIcon.textContent = "♥";
      likeButton?.classList.add("text-black");
    }
    const endpoint =
    type === "wall-project"
      ? "wall-projects"
      : "artworks";

    if (localStorage.getItem(viewedKey) !== "true") {
      localStorage.setItem(viewedKey, "true");

      fetch(`${apiUrl}/public/${endpoint}/${slug}/view`, {
        method: "POST",
      })
        .then((res) => res.json())
        .then((json) => {
          if (viewCountEl && json.data?.viewCount !== undefined) {
            viewCountEl.textContent = String(json.data.viewCount);
          }
        })
        .catch(console.error);
    }

    likeButton?.addEventListener("click", async () => {
      if (localStorage.getItem(likedKey) === "true") return;

      localStorage.setItem(likedKey, "true");
      likeIcon.textContent = "♥";
      likeButton.classList.add("text-black");

      try {
        const res = await fetch(`${apiUrl}/public/${endpoint}/${slug}/like`, {
          method: "POST",
        });

        const json = await res.json();

        if (likeCountEl && json.data?.likeCount !== undefined) {
          likeCountEl.textContent = String(json.data.likeCount);
        }
      } catch (error) {
        console.error(error);
      }
    });
  });
</script>