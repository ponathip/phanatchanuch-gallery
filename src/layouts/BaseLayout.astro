---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import "../styles/global.css";
import { apiData } from "../lib/api";

interface Props {
  title: string;
  description: string;
  lang?: "en" | "th";
  image?: string;
}

const {
  title,
  description,
  lang = "en",
  image = "/images/og.jpg",
} = Astro.props;

let settings = {};

try {
  settings = await apiData("/public/settings");
} catch (_) {
  settings = {};
}

const siteName = settings.siteName ?? "PhanatchaNuch";
const finalTitle = title ?? settings.defaultTitle ?? siteName;
const finalDescription =
  description ??
  settings.defaultDescription ??
  "Original artworks, wall painting, and exhibitions by PhanatchaNuch.";

const finalImage =
  image ??
  settings.defaultOgImage ??
  settings.profileImageUrl ??
  "/images/og-default.jpg";

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
---

<!doctype html>
<html lang={lang} translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#000000" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="PhanatchaNuch" />
    <meta name="google" content="notranslate" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:image" content={finalImage} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="alternate" hreflang="en" href={new URL(Astro.url.pathname.replace(/^\/th/, "/en"), site.url)} />
    <link rel="alternate" hreflang="th" href={new URL(Astro.url.pathname.replace(/^\/en/, "/th"), site.url)} />

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=Noto+Sans+Thai:wght@300;400;500&family=Noto+Serif+Thai:wght@400;500;600&display=swap" rel="stylesheet">

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "PhanatchaNuch",
        url: site.url,
        sameAs: [`https://instagram.com/${site.instagram}`],
        jobTitle: "Contemporary Artist",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Bangkok",
          addressCountry: "Thailand",
        },
      })}
    />
  </head>

  <body>
    <Header lang={lang} />
    <main class="page-fade">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
