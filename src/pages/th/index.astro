---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { apiData } from "../../lib/api";

const settings = await apiData("/public/settings");
const artworks = await apiData("/public/artworks");
const wallProjects = await apiData("/public/wall-projects");
const exhibitions = await apiData("/public/exhibitions");

const selectedWorks = artworks.slice(0, 6);
const heroWork = artworks[0];
const featuredWall = wallProjects[0];
const currentExhibition = exhibitions[0];
---

<BaseLayout
  lang="th"
  title={settings.defaultTitle}
  description={settings.defaultDescription}
  image={heroWork?.coverImageUrl ?? settings.defaultOgImage}
>
  <!-- HERO -->
  <section class="mx-auto grid min-h-screen max-w-7xl gap-12 px-5 pt-28 lg:grid-cols-[0.9fr_1.1fr] lg:items-center md:px-8">
    <div class="order-2 md:order-1">
      <p class="mb-8 text-xs uppercase tracking-[0.24em] text-black/45">
        Contemporary Artist
      </p>

      <h1 class="serif max-w-full break-words text-[48px] leading-[0.95] sm:text-6xl md:text-8xl first-letter:text-[1.18em] first-letter:mr-[1px]">
        PhanatchaNuch
      </h1>

      <div class="my-10 h-px w-20 bg-black"></div>

      <p class="max-w-md text-sm leading-8 text-black/65">
        โลกทัศน์ทางศิลปะที่เงียบ เรียบ และลึก ผ่าน texture, memory,
        silence และร่องรอยทางอารมณ์ในผลงานนามธรรม
      </p>

      <div class="mt-12 flex flex-col gap-4 sm:flex-row">
        <a
          href="/th/gallery"
          class="inline-flex items-center justify-between bg-black px-7 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
        >
          ดูแกลเลอรี <span class="ml-8">→</span>
        </a>

        <a
          href="/th/profile"
          class="inline-flex items-center justify-between border border-black/20 px-7 py-4 text-xs uppercase tracking-[0.2em] transition hover:border-black"
        >
          โปรไฟล์ศิลปิน <span class="ml-8">→</span>
        </a>
      </div>
    </div>

    <div class="order-1 md:order-2">
      <div class="relative">
        <img
          src={heroWork?.coverImageUrl}
          alt={`${heroWork.title} โดย PhanatchaNuch`}
          class="image-soft h-[520px] w-full object-cover md:h-[720px]"
          loading="eager"
        />

        <div class="absolute bottom-0 left-0 max-w-xs bg-[#f7f7f4]/90 p-5 backdrop-blur">
          <p class="serif text-xl">{heroWork.title}</p>
          <p class="mt-2 text-xs uppercase tracking-[0.18em] text-black/45">
            {heroWork?.year} · {heroWork?.category}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SELECTED WORKS -->
  <section class="mx-auto max-w-7xl border-t border-black/10 px-5 py-20 md:px-8">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr] md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          Selected Works
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          ผลงานที่คัดสรร
        </h2>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        รวมผลงานล่าสุดที่สำรวจ texture, memory, silence และพื้นที่ทางอารมณ์
        ราคาจะไม่แสดงบนเว็บไซต์ และจะพูดคุยเป็นการส่วนตัว
      </p>
    </div>

    <div class="mt-14 grid gap-x-6 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
      {selectedWorks.map((art, index) => {
        const isTall = index === 1 || index === 4;

        return (
          <a href={`/th/artworks/${art.slug}`} class="group">
            <div class="relative overflow-hidden bg-black/5">
              <img
                src={art.coverThumbUrl ?? art.coverImageUrl}
                alt={`${art.title} โดย PhanatchaNuch`}
                class:list={[
                  "w-full object-cover transition duration-700 group-hover:scale-105",
                  isTall ? "aspect-[3/4]" : "aspect-square",
                ]}
                loading="lazy"
              />

              <div class="absolute inset-0 bg-black/0 transition group-hover:bg-black/10"></div>

              <div class="absolute bottom-4 right-4 opacity-0 transition duration-500 group-hover:opacity-100">
                <span class="rounded-full bg-black px-4 py-2 text-[10px] uppercase tracking-[0.18em] text-white">
                  ดูผลงาน →
                </span>
              </div>
            </div>

            <div class="mt-5 flex items-start justify-between gap-5">
              <div>
                <h3 class="serif text-2xl leading-tight">{art.title}</h3>
                <p class="mt-2 text-sm text-black/50">
                  {art.year} · {art.medium}
                </p>
              </div>

              <span class="hidden text-xs uppercase tracking-[0.18em] text-black/35 md:block">
                {String(index + 1).padStart(2, "0")}
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-14 text-center">
      <a
        href="/th/gallery"
        class="inline-flex border-b border-black pb-2 text-xs uppercase tracking-[0.2em]"
      >
        ดูผลงานทั้งหมด →
      </a>
    </div>
  </section>

  <!-- WALL PAINTING -->
  <section class="bg-[#f7f7f4]">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.85fr_1.15fr] md:items-center md:px-8">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Wall Painting
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          งานศิลปะสำหรับพื้นที่จริง
        </h2>

        <p class="mt-8 max-w-md text-sm leading-8 text-black/65">
          งานวาดภาพผนังแบบเฉพาะพื้นที่ สำหรับบ้าน คาเฟ่ โรงแรม แกลเลอรี
          ออฟฟิศ และพื้นที่สร้างสรรค์
        </p>

        <a
          href="/th/wall-painting"
          class="mt-10 inline-flex border-b border-black pb-2 text-xs uppercase tracking-[0.2em]"
        >
          ดูงาน Wall Painting →
        </a>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {wallProjects.slice(0, 2).map((item) => (
          <img
            src={item.coverThumbUrl ?? item.coverImageUrl}
            alt={`${item.title} by PhanatchaNuch`}
            class="mt-16 h-[460px] w-full object-cover"
            loading="lazy"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- EXHIBITION -->
  <section class="bg-black text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.75fr_1.25fr] md:px-8">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-white/45">
          Current Exhibition
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          {currentExhibition?.title}
        </h2>

        <p class="mt-8 text-xs uppercase leading-7 tracking-[0.18em] text-white/65">
          {currentExhibition?.exhibitionDate}<br />
          {currentExhibition?.venue}
        </p>

        <a
          href="/th/exhibitions"
          class="mt-10 inline-flex border-b border-white pb-2 text-xs uppercase tracking-[0.2em]"
        >
          ดูนิทรรศการ →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-[1.1fr_0.9fr]">
        <img
          src={currentExhibition?.coverImageUrl}
          alt="นิทรรศการ Echoes in Between"
          class="h-[520px] w-full object-cover opacity-85"
          loading="lazy"
        />

        <div class="flex flex-col justify-between border border-white/15 p-8">
          <p class="text-sm leading-8 text-white/65">
            นิทรรศการที่สำรวจความทรงจำ ความเงียบ และร่องรอยทางอารมณ์
            ผ่านพื้นผิวและภาษาภาพแบบนามธรรม
          </p>

          <div class="mt-12 space-y-5 text-xs uppercase tracking-[0.18em] text-white/50">
            <p>Solo Presentation</p>
            <p>Mixed Media</p>
            <p>Artist: PhanatchaNuch</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROFILE -->
  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="grid gap-10 md:grid-cols-[1fr_1fr] md:items-center">
      <div class="grid grid-cols-2 gap-4">
        <img
          src={settings.profileImageUrl}
          alt="ภาพศิลปิน PhanatchaNuch"
          class="h-[460px] w-full object-cover grayscale"
          loading="lazy"
        />

        <img
          src={settings.defaultOgImage}
          alt="รายละเอียดผลงานโดย PhanatchaNuch"
          class="mt-16 h-[460px] w-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="md:pl-12">
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          {settings.bioTh}
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          การทำงานที่เริ่มจากความเงียบ
        </h2>

        <p class="mt-8 max-w-md text-sm leading-8 text-black/65">
          PhanatchaNuch สร้างผลงานนามธรรมที่แปลความทรงจำ อารมณ์
          และภูมิทัศน์ภายในที่มองไม่เห็น ออกมาเป็นภาษาภาพแบบ layered
        </p>

        <a
          href="/th/profile"
          class="mt-10 inline-flex border-b border-black pb-2 text-xs uppercase tracking-[0.2em]"
        >
          อ่านโปรไฟล์ →
        </a>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="mx-auto max-w-7xl border-t border-black/10 px-5 py-20 md:px-8">
    <div class="flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          Artwork Inquiry
        </p>

        <h2 class="serif max-w-2xl text-5xl leading-tight md:text-6xl">
          สนใจผลงานหรือโปรเจกต์?
        </h2>

        <p class="mt-6 max-w-md text-sm leading-7 text-black/60">
          ติดต่อเพื่อพูดคุยเกี่ยวกับผลงาน งานวาดภาพผนัง นิทรรศการ
          หรือการร่วมงานแบบส่วนตัว
        </p>
      </div>

      <a
        href="/th/contact"
        class="inline-flex min-w-[150px] items-center justify-between whitespace-nowrap bg-black px-6 py-4 text-[11px] uppercase tracking-[0.16em] text-white transition hover:bg-black/80 md:min-w-[170px] md:px-8"
      >
        ติดต่อ →
      </a>
    </div>
  </section>
</BaseLayout>