---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { apiData } from "../../../lib/api";
import ImageCarousel from "../../../components/ImageCarousel.astro";
import StatsBar from "../../../components/StatsBar.astro";

const artworkSlug = decodeURIComponent(
  Astro.url.pathname.split("/").filter(Boolean).at(-1) ?? "",
);

if (!artworkSlug || artworkSlug === "[object Object]") {
  throw new Error("Invalid artwork slug");
}

const art = await apiData(`/public/artworks/${artworkSlug}`);
const allArtworks = await apiData("/public/artworks");

const relatedWorks = allArtworks
  .filter((item) => item.slug !== art.slug)
  .slice(0, 3);
---

<BaseLayout
  lang="th"
  title={`${art.title} | PhanatchaNuch`}
  description={`ชมรายละเอียดผลงาน ${art.title} โดย PhanatchaNuch`}
  image={art.image}
>
  <section
    class="mx-auto max-w-7xl border-t border-black/10 px-5 py-20 md:px-8"
  >
    <a
      href="/th/gallery"
      class="mb-10 inline-flex text-xs uppercase tracking-[0.22em] text-black/50 hover:text-black"
    >
      ← กลับไปหน้าแกลเลอรี
    </a>

    <div class="grid min-w-0 gap-10 lg:grid-cols-[minmax(0,1fr)_360px] xl:grid-cols-[minmax(0,1fr)_420px] xl:gap-14">
      <div class="min-w-0 max-w-full overflow-hidden">
        <ImageCarousel
          images={art.images?.length
            ? art.images.map((img) => img.imageUrl)
            : [art.coverImageUrl ?? art.coverThumbUrl]}
          title={`${art.title} by PhanatchaNuch`}
        />
      </div>

      <aside class="min-w-0 lg:sticky lg:top-28 lg:h-fit">
        <div class="border-y border-black/10 py-8">
          <p class="mb-6 text-xs uppercase tracking-[0.22em] text-black/45">
            งานศิลปะ
          </p>

          <h1 class="serif text-[44px] leading-[1.05] md:text-[56px] xl:text-7xl">
            {art.title}
          </h1>

          <p class="mt-6 text-sm uppercase tracking-[0.18em] text-black/45">
            PhanatchaNuch, {art.year}
          </p>
        </div>

        <StatsBar
          type="artwork"
          lang="th"
          slug={art.slug}
          viewCount={art.viewCount}
          likeCount={art.likeCount}
        />

        <div
          class="grid grid-cols-2 gap-x-8 gap-y-6 border-b border-black/10 py-8 text-sm"
        >
          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
              เทคนิค
            </p>
            <p class="mt-2 text-black/70">{art.medium}</p>
          </div>

          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
              ขนาด
            </p>
            <p class="mt-2 text-black/70">{art.size}</p>
          </div>

          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
              สถานะ
            </p>
            <p class="mt-2 text-black/70">{art.status}</p>
          </div>

          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
              หมวดหมู่
            </p>
            <p class="mt-2 text-black/70">{art.category}</p>
          </div>
        </div>

        <div class="border-b border-black/10 py-8">
          <p class="mb-4 text-[11px] uppercase tracking-[0.2em] text-black/40">
            บทความอธิบาย
          </p>

          <p class="text-sm leading-8 text-black/70">
            {art.description}
          </p>
        </div>

        <div class="space-y-4 py-8">
          <a
            href={`/th/contact?type=artwork&artworkId=${art.id}&artwork=${encodeURIComponent(art.title)}`}
            class="flex w-full items-center justify-between bg-black px-6 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
          >
            สอบถามผลงานนี้ <span>→</span>
          </a>

          <a
            href="/th/gallery"
            class="flex w-full items-center justify-between border border-black/20 px-6 py-4 text-xs uppercase tracking-[0.2em] transition hover:border-black"
          >
            ดูผลงานเพิ่มเติม <span>→</span>
          </a>

          <p class="pt-3 text-xs leading-6 text-black/45">
            ราคาจะไม่แสดงบนเว็บไซต์ การสอบถามทั้งหมดจะพูดคุยเป็นการส่วนตัว
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section
    class="mx-auto max-w-7xl border-t border-black/10 px-5 py-20 md:px-8"
  >
    <div class="mb-10 flex items-end justify-between gap-6">
      <div>
        <p class="mb-4 text-xs uppercase tracking-[0.22em] text-black/45">
          ผลงานอื่น เพิ่มเติม
        </p>
        <h2 class="serif text-4xl md:text-5xl">ผลงานอื่น ๆ</h2>
      </div>

      <a
        href="/th/gallery"
        class="hidden text-xs uppercase tracking-[0.2em] md:block"
      >
        ดูทั้งหมด →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
      {
        relatedWorks.map((item) => (
          <a href={`/th/artworks/${item.slug}`} class="group">
            <div class="overflow-hidden bg-black/5">
              <img
                src={item.coverThumbUrl}
                alt={`${item.title} โดย PhanatchaNuch`}
                class="aspect-square w-full object-cover transition duration-700 group-hover:scale-[1.03]"
                loading="lazy"
              />
            </div>

            <h3 class="serif mt-4 text-2xl">{item.title}</h3>
            <p class="mt-1 text-sm text-black/50">
              {item.year} · {item.category}
            </p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL }}>
  const slug = location.pathname.split("/").filter(Boolean).at(-1);

  if (slug) {
    fetch(`${apiUrl}/public/artworks/${slug}/view`, {
      method: "POST",
    }).catch(console.error);
  }
</script>
