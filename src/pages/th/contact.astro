---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
---

<BaseLayout
  lang="th"
  title="ติดต่อ PhanatchaNuch | สอบถามผลงาน"
  description="ติดต่อ PhanatchaNuch สำหรับสอบถามผลงานศิลปะ งานวาดภาพผนัง นิทรรศการ หรือการร่วมงาน"
>
  <section class="mx-auto grid min-h-screen max-w-7xl gap-14 px-5 pb-24 pt-32 md:grid-cols-[0.8fr_1.2fr] md:px-8">
    <div class="flex flex-col justify-between">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          ติดต่อ
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          สนใจผลงานหรือโปรเจกต์?
        </h1>

        <p class="mt-8 max-w-md text-sm leading-8 text-black/65">
          ติดต่อเพื่อสอบถามผลงาน งานวาดภาพผนัง นิทรรศการ การร่วมงาน
          หรือการนัดชมผลงานแบบส่วนตัว
        </p>
      </div>

      <div class="mt-14 grid gap-6 border-y border-black/10 py-8 text-sm sm:grid-cols-2">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Email</p>
          <p class="text-\[12px\] mt-3 text-black/70">{site.email}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Instagram</p>
          <p class="text-\[12px\] mt-3 text-black/70">{site.instagram}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Location</p>
          <p class="text-\[12px\] mt-3 text-black/70">{site.location.th ?? site.location.en}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Response</p>
          <p class="text-\[12px\] mt-3 text-black/70">โดยปกติตอบกลับภายใน 24 ชั่วโมง</p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 md:p-10">
      <form id="contactForm" class="space-y-7">
        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            ชื่อ
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="text"
            name="name"
            placeholder="ชื่อของคุณ"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            อีเมล
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            ประเภทการติดต่อ
          </label>
          <select
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="inquiryType"
          >
            <option value="artwork">สอบถามผลงานศิลปะ</option>
            <option value="wall-painting">งานวาดภาพผนัง</option>
            <option value="exhibition">นิทรรศการ</option>
            <option value="collaboration">การร่วมงาน</option>
            <option value="private-viewing">นัดชมผลงานส่วนตัว</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            ข้อความ
          </label>
          <textarea
            class="mt-3 h-44 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="message"
            placeholder="เล่าให้เราฟังเกี่ยวกับผลงานหรือโปรเจกต์ที่คุณสนใจ..."
            required
          ></textarea>
        </div>

        <button
          class="flex w-full items-center justify-between bg-black px-7 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
          type="submit"
        >
          ส่งข้อความ <span>→</span>
        </button>

        <div
          id="formMessage"
          class="hidden border border-black/10 bg-[#f7f7f4] p-5 text-sm leading-7 text-black/70"
        >
          ส่งข้อความเรียบร้อยแล้ว ขณะนี้เป็นฟอร์มตัวอย่างสำหรับ preview
        </div>

        <p class="text-\[12px\] leading-6 text-black/45">
          การสอบถามทั้งหมดเป็นแบบส่วนตัว ราคาจะไม่แสดงบนเว็บไซต์
          และจะพูดคุยรายละเอียดเป็นรายกรณี
        </p>
      </form>
    </div>
  </section>

  <script define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL }}>
  const form = document.getElementById("contactForm");
  const messageBox = document.getElementById("formMessage");

  const params = new URLSearchParams(window.location.search);

  const type = params.get("type");
  const artworkId = params.get("artworkId");
  const artwork = params.get("artwork");
  const project = params.get("project");

  const typeSelect = form?.querySelector("select[name='inquiryType']");
  const messageInput = form?.querySelector("textarea[name='message']");
  const submitButton = form?.querySelector("button[type='submit']");

  if (typeSelect instanceof HTMLSelectElement && type) {
    typeSelect.value = type;
  }

  if (messageInput instanceof HTMLTextAreaElement) {
    if (type === "artwork" && artwork) {
      messageInput.value = `Hello, I am interested in the artwork: ${artwork}. Please share more details.`;
    }

    if (type === "wall_painting") {
      messageInput.value =
        "Hello, I am interested in a custom wall painting project. I would like to discuss my space, idea, and timeline.";
    }

    if (type === "collaboration") {
      messageInput.value =
        "Hello, I am interested in a collaboration. Please share more details.";
    }

    if (type === "exhibition") {
      messageInput.value =
        "Hello, I am interested in exhibition opportunities. Please share more details.";
    }

    if (type === "private_viewing") {
      messageInput.value =
        "Hello, I am interested in a private viewing. Please share more details.";
    }

    if (project) {
      messageInput.value = `Hello, I am interested in a wall painting project related to: ${project}. Please share more details.`;
    }
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!(form instanceof HTMLFormElement)) return;

    const formData = new FormData(form);

    const payload = {
      name: formData.get("name"),
      email: formData.get("email"),
      inquiryType: formData.get("inquiryType"),
      artworkId: artworkId ? Number(artworkId) : null,
      message: formData.get("message"),
    };

    try {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = "Sending...";
      }

      const res = await fetch(`${apiUrl}/public/inquiries`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        throw new Error("Failed to send inquiry");
      }

      form.reset();

      if (messageBox) {
        messageBox.classList.remove("hidden");
        messageBox.textContent =
          "Message sent successfully. Thank you for your inquiry.";
      }
    } catch (error) {
      console.error(error);

      if (messageBox) {
        messageBox.classList.remove("hidden");
        messageBox.textContent =
          "Message could not be sent. Please try again.";
      }
    } finally {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = false;
        submitButton.innerHTML = `Send Message <span>→</span>`;
      }
    }
  });
</script>
</BaseLayout>