---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
---

<BaseLayout
  lang="th"
  title="ติดต่อ PhanatchaNuch | Artwork Inquiry"
  description="ติดต่อ PhanatchaNuch เพื่อสอบถามผลงาน การร่วมงาน หรือนิทรรศการ"
>
  <section class="mx-auto grid min-h-screen max-w-7xl gap-14 px-5 pb-24 pt-32 md:grid-cols-[0.8fr_1.2fr] md:px-8">
    <div class="flex flex-col justify-between">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Contact
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          สนใจผลงานชิ้นไหน?
        </h1>

        <p class="mt-8 max-w-md text-sm leading-8 text-black/65">
          สามารถติดต่อเพื่อพูดคุยเกี่ยวกับผลงาน นิทรรศการ การร่วมงาน
          หรือการเข้าชมแบบส่วนตัวได้ผ่านแบบฟอร์มนี้
        </p>
      </div>

      <div class="mt-14 grid gap-6 border-y border-black/10 py-8 text-sm sm:grid-cols-2">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Email</p>
          <p class="mt-3 text-black/70">{site.email}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Instagram</p>
          <p class="mt-3 text-black/70">@{site.instagram}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Location</p>
          <p class="mt-3 text-black/70">{site.location.th}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Response</p>
          <p class="mt-3 text-black/70">ตอบกลับโดยเร็วที่สุด</p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 md:p-10">
      <form id="contactForm" class="space-y-7">
        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Name
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="text"
            name="name"
            placeholder="ชื่อของคุณ"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Email
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Inquiry Type
          </label>
          <select
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="type"
          >
            <option>สอบถามผลงาน</option>
            <option>นิทรรศการ</option>
            <option>การร่วมงาน</option>
            <option>เข้าชมแบบส่วนตัว</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Message
          </label>
          <textarea
            class="mt-3 h-44 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="message"
            placeholder="บอกเราว่าคุณสนใจผลงานหรือโปรเจกต์แบบไหน..."
            required
          ></textarea>
        </div>

        <button
          class="flex w-full items-center justify-between bg-black px-7 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
          type="submit"
        >
          ส่งข้อความ <span>→</span>
        </button>

        <div
          id="formMessage"
          class="hidden border border-black/10 bg-[#f7f7f4] p-5 text-sm leading-7 text-black/70"
        >
          ส่งข้อความสำเร็จแล้ว นี่คือฟอร์ม mockup สำหรับพรีวิว
        </div>

        <p class="text-xs leading-6 text-black/45">
          ทุกข้อความเป็นส่วนตัว เว็บไซต์ไม่แสดงราคาออนไลน์ และจะพูดคุยรายละเอียดโดยตรง
        </p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById("contactForm");
    const message = document.getElementById("formMessage");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      form.reset();
      message?.classList.remove("hidden");
    });
  </script>
</BaseLayout>