---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { apiData } from "../../../lib/api";
import ImageCarousel from "../../../components/ImageCarousel.astro";
import StatsBar from "../../../components/StatsBar.astro";

const slug = decodeURIComponent(
  Astro.url.pathname.split("/").filter(Boolean).at(-1) ?? ""
);

const project = await apiData(`/public/wall-projects/${slug}`);
const allProjects = await apiData("/public/wall-projects");

const relatedProjects = allProjects
  .filter((item) => item.slug !== project.slug)
  .slice(0, 3);

const carouselImages = project.images?.length
  ? project.images.map((img) => img.imageUrl)
  : [project.coverImageUrl].filter(Boolean);
---

<BaseLayout
  lang="th"
  title={`${project.title} | งานวาดภาพผนัง | PhanatchaNuch`}
  description={project.description}
  image={project.coverImageUrl}
>
  <section class="mx-auto max-w-7xl px-5 pb-0 pt-32 md:px-8">
    <a
      href="/th/wall-painting"
      class="mb-10 inline-flex text-xs uppercase tracking-[0.22em] text-black/50 hover:text-black"
    >
      ← กลับไปหน้า Wall Painting
    </a>

    <div class="grid gap-12 md:grid-cols-[0.85fr_1.15fr] md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          งานวาดภาพผนัง
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          {project.title}
        </h1>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        {project.description}
      </p>
    </div>

    <div class="mt-16 overflow-hidden bg-black/5">
      <ImageCarousel
        images={carouselImages}
        title={`${project.title} wall painting by PhanatchaNuch`}
      />
    </div>

    <StatsBar
      type="wall-project"
      slug={project.slug}
      viewCount={project.viewCount}
      likeCount={project.likeCount}
      lang="th"
    />
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-20 md:px-8">
    <div class="grid gap-6 border-y border-black/10 py-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">
          สถานที่
        </p>
        <p class="mt-3 text-sm text-black/70">{project.location}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">
          ปี
        </p>
        <p class="mt-3 text-sm text-black/70">{project.year}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">
          พื้นที่
        </p>
        <p class="mt-3 text-sm text-black/70">{project.spaceType}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">
          ความคืบหน้า
        </p>
        <p class="mt-3 text-sm text-black/70">{project.status}</p>
      </div>
    </div>
  </section>

  <section class="bg-black text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.7fr_1.3fr] md:px-8">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-white/45">
          แนวคิดโครงการ
        </p>
      </div>

      <div>
        <h2 class="serif max-w-4xl text-4xl leading-tight md:text-6xl">
          งานศิลปะที่ถูกสร้างขึ้นเพื่อความรู้สึกของพื้นที่
        </h2>

        <p class="mt-10 max-w-2xl text-sm leading-8 text-white/65">
          {project.concept}
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="mb-12 grid gap-10 md:grid-cols-[0.85fr_1.15fr] md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          ก่อน / หลัง
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          การเปลี่ยนแปลงของพื้นที่
        </h2>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        งานวาดภาพผนังสามารถเปลี่ยนตัวตนของห้อง และสร้างบรรยากาศเฉพาะที่เป็นของพื้นที่นั้นจริง ๆ
      </p>
    </div>

    <div class="grid overflow-hidden border border-black/10 md:grid-cols-2">
      <div class="relative bg-black/5">
        <img
          src={project.beforeImageUrl}
          alt={`${project.title} ก่อนวาดภาพผนัง`}
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
        />

        <span class="absolute bottom-5 left-5 rounded-full bg-black px-5 py-3 text-[10px] uppercase tracking-[0.18em] text-white">
          ก่อน
        </span>
      </div>

      <div class="relative bg-black/5">
        <img
          src={project.afterImageUrl}
          alt={`${project.title} หลังวาดภาพผนังโดย PhanatchaNuch`}
          class="aspect-[4/3] w-full object-cover"
          loading="lazy"
        />

        <span class="absolute bottom-5 right-5 rounded-full bg-black px-5 py-3 text-[10px] uppercase tracking-[0.18em] text-white">
          หลัง
        </span>
      </div>
    </div>
  </section>

  <section class="bg-[#f7f7f4]">
    <div class="mx-auto max-w-7xl px-5 py-24 md:px-8">
      <div class="mb-12 flex flex-col justify-between gap-8 md:flex-row md:items-end">
        <div>
          <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
            โครงการที่เกี่ยวข้อง
          </p>

          <h2 class="serif text-5xl leading-tight md:text-7xl">
            โปรเจกต์อื่น ๆ
          </h2>
        </div>

        <a
          href="/th/wall-painting"
          class="inline-flex border-b border-black pb-2 text-xs uppercase tracking-[0.2em]"
        >
          ดูทั้งหมด →
        </a>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3">
        {relatedProjects.map((item) => (
          <a href={`/th/wall-painting/${item.slug}`} class="group">
            <div class="overflow-hidden bg-black/5">
              <img
                src={item.coverThumbUrl ?? item.coverImageUrl}
                alt={`${item.title} งานวาดภาพผนังโดย PhanatchaNuch`}
                class="aspect-[4/5] w-full object-cover transition duration-700 group-hover:scale-105"
                loading="lazy"
              />
            </div>

            <h3 class="serif mt-5 text-2xl">{item.title}</h3>
            <p class="mt-2 text-sm text-black/50">
              {item.year} · {item.location}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  {
    project.videoEmbedUrl && (
      <section class="mx-auto max-w-7xl px-5 pb-20 md:px-8">
        <div class="border-t border-black/10 pt-16">
          <div class="mb-10 grid gap-8 md:grid-cols-[0.7fr_1.3fr] md:items-end">
            <div>
              <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
                วิดีโอโครงการ
              </p>

              <h2 class="serif text-5xl leading-tight md:text-7xl">
                เบื้องหลังงาน
              </h2>
            </div>

            <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
              ชมขั้นตอน บรรยากาศ และผลงานจิตรกรรมฝาผนังที่เสร็จสมบูรณ์ โครงการ
            </p>
          </div>

          <div
            class={
              project.videoPlatform === "youtube"
                ? "overflow-hidden bg-black"
                : "mx-auto max-w-md overflow-hidden bg-black"
            }
          >
            <iframe
              src={project.videoEmbedUrl}
              title={`${project.title} video`}
              class={
                project.videoPlatform === "youtube"
                  ? "aspect-video w-full"
                  : "h-[680px] w-full"
              }
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            />
          </div>
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="flex flex-col justify-between gap-10 border-y border-black/10 py-16 md:flex-row md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          สอบถามโครงการ
        </p>

        <h2 class="serif max-w-3xl text-5xl leading-tight md:text-7xl">
          สนใจทำงานวาดภาพผนังสำหรับพื้นที่ของคุณ?
        </h2>

        <p class="mt-7 max-w-md text-sm leading-8 text-black/60">
          เล่าเรื่องพื้นที่ ไอเดีย ระยะเวลา และทิศทางที่ต้องการได้เลย
          ทุกโปรเจกต์จะพูดคุยรายละเอียดเป็นรายกรณี
        </p>
      </div>

      <a
        href={`/th/contact?type=wall_painting&project=${encodeURIComponent(project.title)}`}
        class="inline-flex items-center justify-between bg-black px-8 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
      >
        ปรึกษาโปรเจกต์ <span class="ml-8">→</span>
      </a>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ apiUrl: import.meta.env.PUBLIC_API_URL }}>
  const slug = location.pathname.split("/").filter(Boolean).at(-1);

  if (slug) {
    fetch(`${apiUrl}/public/wall-projects/${slug}/view`, {
      method: "POST",
    }).catch(console.error);
  }
</script>