---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { apiData } from "../../lib/api";

const settings = await apiData("/public/settings");
const artworks = await apiData("/public/artworks");
const exhibitions = await apiData("/public/exhibitions");

const featuredArtworks = artworks.slice(0, 3);
const selectedExhibitions = exhibitions.slice(0, 3);
---

<BaseLayout
  lang="th"
  title="เกี่ยวกับ PhanatchaNuch | โปรไฟล์ศิลปิน"
  description="เรียนรู้เพิ่มเติมเกี่ยวกับ PhanatchaNuch ศิลปินร่วมสมัยที่สำรวจความทรงจำ พื้นผิว และอารมณ์ผ่านผลงานนามธรรม"
  image={settings.profileImageUrl ?? settings.defaultOgImage}
>
  <section class="mx-auto grid max-w-7xl gap-12 px-5 pb-24 pt-32 md:grid-cols-[0.95fr_1.05fr] md:px-8">
    <div>
      <img
        src={settings.profileImageUrl ?? "/images/profile/artist.jpg"}
        alt="ภาพศิลปิน PhanatchaNuch"
        class="h-[560px] w-full object-cover md:h-[760px]"
        loading="eager"
      />
    </div>

    <div class="flex flex-col justify-center">
      <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
        {settings.aboutTitleTh ?? "PhanatchaNuch"}
      </p>

      <h1 class="serif max-w-full break-words leading-[0.95] text-[36px] sm:text-5xl md:text-7xl">
        {settings.bioTh}
      </h1>

      <p class="mt-8 max-w-xl text-lg leading-9 text-black/65">
        {settings.artistStatementTh}
      </p>

      <div class="mt-12 grid gap-6 border-y border-black/10 py-8 sm:grid-cols-3">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Based In
          </p>
          <p class="mt-3 text-sm text-black/70">
            Chachoengsao, Thailand
          </p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Focus
          </p>
          <p class="mt-3 text-sm text-black/70">
            Abstract / Mixed Media
          </p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Language
          </p>
          <p class="mt-3 text-sm text-black/70">
            Thai / English
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-black text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.7fr_1.3fr] md:px-8">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-white/45">
          สารจากศิลปิน
        </p>
      </div>

      <div>
        <h2 class="serif max-w-4xl text-4xl leading-tight md:text-6xl">
          ผลงานของฉันเริ่มต้นในพื้นที่ที่ภาษาเริ่มเงียบลง
        </h2>

        <p class="mt-10 max-w-2xl text-sm leading-8 text-white/65">
          ผ่านงานนามธรรม ฉันสำรวจความสัมพันธ์ระหว่างความทรงจำ อารมณ์
          และร่างกาย พื้นผิวที่ซ้อนทับ โทนสีที่สงบ และ gesture ที่เงียบ
          กลายเป็นวิธีเก็บรักษาสิ่งที่ไม่สามารถอธิบายได้ทั้งหมดด้วยคำพูด
        </p>

        <p class="mt-6 max-w-2xl text-sm leading-8 text-white/65">
          แต่ละชิ้นงานไม่ได้ถูกสร้างขึ้นเพื่ออธิบายเหตุการณ์ใดเหตุการณ์หนึ่ง
          แต่เพื่อรักษาบรรยากาศรอบ ๆ เหตุการณ์นั้นไว้ ทั้งความเงียบ
          ร่องรอย และสิ่งที่ยังคงหลงเหลืออยู่
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="grid gap-12 md:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          ฝึกฝน
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          พื้นผิวในฐานะความทรงจำ
        </h2>
      </div>

      <div class="grid gap-10 md:grid-cols-2">
        <p class="text-sm leading-8 text-black/65">
          การทำงานของ PhanatchaNuch ให้ความสำคัญกับองค์ประกอบนามธรรม
          ที่ถ่ายทอดน้ำหนักทางอารมณ์ผ่านพื้นผิว จังหวะ และความเงียบ
        </p>

        <p class="text-sm leading-8 text-black/65">
          แทนที่จะเล่าเรื่องอย่างตรงไปตรงมา ผลงานชวนให้ผู้ชมเข้าไปอยู่ในพื้นที่ของการครุ่นคิด
          ที่ซึ่งความรู้สึกกลายเป็นภาษาหลักของการรับรู้
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-24 md:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      {featuredArtworks.map((art, index) => (
        <img
          src={art.coverThumbUrl ?? art.coverImageUrl}
          alt={art.title}
          class:list={[
            "w-full object-cover",
            index === 1 ? "h-[560px] md:mt-20" : "h-[460px]",
          ]}
          loading="lazy"
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl border-y border-black/10 px-5 py-16 md:px-8">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          ประวัตินิทรรศการ
        </p>

        <h2 class="serif text-5xl leading-tight">
          นิทรรศการที่คัดเลือก
        </h2>
      </div>

      <div class="space-y-6">
        {selectedExhibitions.map((item) => (
          <div class="grid gap-3 border-b border-black/10 pb-6 sm:grid-cols-[100px_1fr]">
            <p class="text-xs uppercase tracking-[0.2em] text-black/40">
              {item.year}
            </p>
            <div>
              <h3 class="serif text-2xl">{item.title}</h3>
              <p class="mt-2 text-sm text-black/55">
                {item.type} · {item.venue}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-20 md:px-8">
    <div class="flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          ติดต่อ
        </p>

        <h2 class="serif max-w-3xl text-5xl leading-tight md:text-7xl">
          สำหรับนิทรรศการ การร่วมงาน หรืองานศิลปะที่คุณสนใจ
        </h2>
      </div>

      <a
        href="/th/contact"
        class="inline-flex bg-black px-8 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
      >
        ติดต่อ →
      </a>
    </div>
  </section>
</BaseLayout>