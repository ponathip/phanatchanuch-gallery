---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import ImageCarousel from "../../../components/ImageCarousel.astro";
import { apiData } from "../../../lib/api";

const slug = decodeURIComponent(
  Astro.url.pathname.split("/").filter(Boolean).at(-1) ?? ""
);

const exhibition = await apiData(`/public/exhibitions/${slug}`);

const images = exhibition.images?.length
  ? exhibition.images.map((img) => img.imageUrl)
  : [exhibition.coverImageUrl].filter(Boolean);

const exhibitionWorks = exhibition.artworks ?? [];
---

<BaseLayout
  lang="th"
  title={`${exhibition.title} | นิทรรศการ | PhanatchaNuch`}
  description={exhibition.descriptionTh ?? exhibition.description}
  image={exhibition.coverImageUrl}
>
  <section class="mx-auto max-w-7xl px-5 pb-20 pt-32 md:px-8">
    <a
      href="/th/exhibitions"
      class="mb-10 inline-flex text-xs uppercase tracking-[0.22em] text-black/50 hover:text-black"
    >
      ← กลับไปหน้านิทรรศการ
    </a>

    <div class="grid gap-12 md:grid-cols-[0.85fr_1.15fr] md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          นิทรรศการ
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          {exhibition.title}
        </h1>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        {exhibition.descriptionTh ?? exhibition.description}
      </p>
    </div>

    <div class="mt-16">
      <ImageCarousel
        images={images}
        title={`${exhibition.title} exhibition by PhanatchaNuch`}
      />
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-20 md:px-8">
    <div class="grid gap-6 border-y border-black/10 py-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">วันที่</p>
        <p class="mt-3 text-sm text-black/70">{exhibition.exhibitionDate}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">สถานที่</p>
        <p class="mt-3 text-sm text-black/70">{exhibition.venue}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">ประเภท</p>
        <p class="mt-3 text-sm text-black/70">{exhibition.type}</p>
      </div>

      <div>
        <p class="text-xs uppercase tracking-[0.22em] text-black/40">ศิลปิน</p>
        <p class="mt-3 text-sm text-black/70">{exhibition.artist}</p>
      </div>
    </div>
  </section>

  <section class="bg-black text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.7fr_1.3fr] md:px-8">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-white/45">
          แนวคิดนิทรรศการ
        </p>
      </div>

      <div>
        <h2 class="serif max-w-4xl text-4xl leading-tight md:text-6xl">
          {exhibition.statementTh ?? exhibition.statement}
        </h2>

        <p class="mt-10 max-w-2xl text-sm leading-8 text-white/65">
          {exhibition.descriptionTh ?? exhibition.description}
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="mb-12 flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          ผลงานในนิทรรศการครั้งนี้
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          ผลงานในนิทรรศการ
        </h2>
      </div>

      <a
        href="/th/gallery"
        class="inline-flex border-b border-black pb-2 text-xs uppercase tracking-[0.2em]"
      >
        ดูผลงานทั้งหมด →
      </a>
    </div>

    {exhibitionWorks.length > 0 ? (
    <div class="grid gap-x-6 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
      {exhibitionWorks.map((art, index) => (
        <a href={`/th/artworks/${art.slug}`} class="group">
          <div class="relative overflow-hidden bg-black/5">
            <img
              src={art.coverImageUrl}
              alt={`${art.title} โดย PhanatchaNuch`}
              class:list={[
                "w-full object-cover transition duration-700 group-hover:scale-105",
                index === 1 || index === 4 ? "aspect-[3/4]" : "aspect-square",
              ]}
              loading="lazy"
            />

            <div class="absolute bottom-4 right-4 opacity-0 transition duration-500 group-hover:opacity-100">
              <span class="rounded-full bg-black px-4 py-2 text-[10px] uppercase tracking-[0.18em] text-white">
                ดูผลงาน →
              </span>
            </div>
          </div>

          <div class="mt-5 flex items-start justify-between gap-5">
            <div>
              <h3 class="serif text-2xl leading-tight">{art.title}</h3>
              <p class="mt-2 text-sm text-black/50">
                {art.year} · {art.category}
              </p>
            </div>

            <span class="hidden text-xs uppercase tracking-[0.18em] text-black/35 md:block">
              {String(index + 1).padStart(2, "0")}
            </span>
          </div>
        </a>
      ))}
    </div>
    ) : (
      <p class="text-sm text-black/50">
        ยังไม่มีการเพิ่มผลงานศิลปะใดๆ เข้าสู่นิทรรศการนี้
      </p>
    )}
  </section>

  <section class="mx-auto max-w-7xl border-t border-black/10 px-5 py-20 md:px-8">
    <div class="flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          เยี่ยมชม / สอบถามข้อมูล
        </p>

        <h2 class="serif max-w-3xl text-5xl leading-tight md:text-7xl">
          ต้องการสอบถามเพิ่มเติมเกี่ยวกับนิทรรศการนี้?
        </h2>

        <p class="mt-6 max-w-md text-sm leading-7 text-black/60">
          ติดต่อเพื่อสอบถามผลงาน รายละเอียดนิทรรศการ หรือการนัดชมผลงานส่วนตัว
        </p>
      </div>

      <a
        href={`/th/contact?type=exhibition&exhibition=${encodeURIComponent(exhibition.title)}`}
        class="inline-flex bg-black px-8 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
      >
        ติดต่อ →
      </a>
    </div>
  </section>
</BaseLayout>