---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { apiData } from "../../lib/api";

type Exhibition = {
  id: number;
  slug: string;
  title: string;
  year: string | null;
  type: string | null;
  venue: string | null;
  exhibitionDate: string | null;
  coverImageUrl: string | null;
  coverThumbUrl: string | null;
  description: string | null;
};

const exhibitions = await apiData<Exhibition[]>("/public/exhibitions");
const featured = exhibitions[0];
---

<BaseLayout
  lang="en"
  title="Exhibitions | PhanatchaNuch"
  description="View current and past exhibitions by PhanatchaNuch."
  image={featured?.coverImageUrl ?? "/images/exhibitions/exhibition-01.jpg"}
>
  <section class="mx-auto max-w-7xl px-5 pb-20 pt-32 md:px-8">
    <div class="grid gap-12 md:grid-cols-[0.8fr_1.2fr] md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Exhibitions
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          Exhibitions
        </h1>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        Current and past exhibitions by PhanatchaNuch, exploring memory,
        silence, texture, and emotional traces through abstract visual language.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-24 md:px-8">
    <div class="grid gap-10">
      {exhibitions.map((exhibition, index) => (
        <a
          href={`/en/exhibitions/${exhibition.slug}`}
          class:list={[
            "group grid gap-8 border-t border-black/10 py-10 lg:grid-cols-[0.8fr_1.2fr]",
            index === exhibitions.length - 1 ? "border-b" : "",
          ]}
        >
          <div class="flex aspect-[4/3] items-center justify-center bg-black/5">
            <img
              src={exhibition.coverThumbUrl ?? exhibition.coverImageUrl ?? "/images/placeholder.jpg"}
              alt={`${exhibition.title} exhibition by PhanatchaNuch`}
              class="max-h-full max-w-full object-contain transition duration-700 group-hover:scale-105"
              loading={index === 0 ? "eager" : "lazy"}
            />
          </div>

          <div class="flex flex-col justify-between">
            <div>
              <p class="mb-6 text-xs uppercase tracking-[0.22em] text-black/40">
                {exhibition.type} · {exhibition.year}
              </p>

              <h2 class="serif text-5xl leading-tight md:text-7xl">
                {exhibition.title}
              </h2>

              <p class="mt-8 max-w-xl text-sm leading-8 text-black/60">
                {exhibition.description}
              </p>
            </div>

            <div class="mt-10 grid gap-5 border-t border-black/10 pt-6 text-sm sm:grid-cols-3">
              <div>
                <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
                  Date
                </p>
                <p class="mt-2 text-black/70">{exhibition.exhibitionDate}</p>
              </div>

              <div>
                <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
                  Venue
                </p>
                <p class="mt-2 text-black/70">{exhibition.venue}</p>
              </div>

              <div>
                <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">
                  View
                </p>
                <p class="mt-2 text-black/70">View Exhibition →</p>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>