---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { artworks } from "../../data/artworks";
---

<BaseLayout
  lang="en"
  title="About PhanatchaNuch | Artist Profile"
  description="Learn more about PhanatchaNuch, a contemporary artist exploring memory, texture, and emotion."
  image="/images/profile/artist.jpg"
>
  <section class="mx-auto grid max-w-7xl gap-12 px-5 pb-24 pt-32 md:grid-cols-[0.95fr_1.05fr] md:px-8">
    <div>
      <img
        src="/images/profile/artist.jpg"
        alt="PhanatchaNuch artist portrait"
        class="h-[560px] w-full object-cover grayscale md:h-[760px]"
        loading="eager"
      />
    </div>

    <div class="flex flex-col justify-center">
      <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
        Artist Profile
      </p>

      <h1 class="serif max-w-full break-words text-[48px] leading-[0.95] sm:text-6xl md:text-8xl">
        PhanatchaKon Phetnak
      </h1>

      <p class="mt-8 max-w-xl text-lg leading-9 text-black/65">
        A contemporary artist exploring memory, texture, silence,
        and the unseen layers of emotion through abstract visual language.
      </p>

      <div class="mt-12 grid gap-6 border-y border-black/10 py-8 sm:grid-cols-3">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Based In</p>
          <p class="mt-3 text-sm text-black/70">Chachoengsao, Thailand</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Focus</p>
          <p class="mt-3 text-sm text-black/70">Abstract / Mixed Media</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Language</p>
          <p class="mt-3 text-sm text-black/70">Thai / English</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-black text-white">
    <div class="mx-auto grid max-w-7xl gap-12 px-5 py-24 md:grid-cols-[0.7fr_1.3fr] md:px-8">
      <div>
        <p class="text-xs uppercase tracking-[0.24em] text-white/45">
          Artist Statement
        </p>
      </div>

      <div>
        <h2 class="serif max-w-4xl text-4xl leading-tight md:text-6xl">
          My work begins where language becomes quiet.
        </h2>

        <p class="mt-10 max-w-2xl text-sm leading-8 text-white/65">
          Through abstraction, I explore the relationship between memory,
          emotion, and the body. Layered surfaces, restrained tones, and quiet
          gestures become a way to hold what cannot be fully spoken.
        </p>

        <p class="mt-6 max-w-2xl text-sm leading-8 text-white/65">
          Each piece is not intended to explain a moment, but to preserve the
          atmosphere around it — the silence, the residue, and the trace that remains.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-24 md:px-8">
    <div class="grid gap-12 md:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Practice
        </p>

        <h2 class="serif text-5xl leading-tight md:text-7xl">
          Texture as memory.
        </h2>
      </div>

      <div class="grid gap-10 md:grid-cols-2">
        <p class="text-sm leading-8 text-black/65">
          PhanatchaNuch’s practice focuses on abstract compositions that carry
          emotional weight through surface, rhythm, and silence.
        </p>

        <p class="text-sm leading-8 text-black/65">
          Rather than presenting direct narratives, the works invite viewers to
          enter a contemplative space where feeling becomes the primary language.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 pb-24 md:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      <img
        src={artworks[0].image}
        alt="Artwork by PhanatchaNuch"
        class="h-[460px] w-full object-cover"
        loading="lazy"
      />

      <img
        src={artworks[1].image}
        alt="Artwork detail by PhanatchaNuch"
        class="h-[560px] w-full object-cover md:mt-20"
        loading="lazy"
      />

      <img
        src={artworks[2].image}
        alt="Abstract artwork by PhanatchaNuch"
        class="h-[460px] w-full object-cover"
        loading="lazy"
      />
    </div>
  </section>

  <section class="mx-auto max-w-7xl border-y border-black/10 px-5 py-16 md:px-8">
    <div class="grid gap-10 md:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          Exhibition History
        </p>

        <h2 class="serif text-5xl leading-tight">
          Selected exhibitions
        </h2>
      </div>

      <div class="space-y-6">
        {[
          ["2026", "Echoes in Between", "Solo Presentation, Bangkok"],
          ["2025", "Traces of Silence", "Group Exhibition, Bangkok"],
          ["2024", "Layers of Being", "Independent Presentation"],
        ].map(([year, title, detail]) => (
          <div class="grid gap-3 border-b border-black/10 pb-6 sm:grid-cols-[100px_1fr]">
            <p class="text-xs uppercase tracking-[0.2em] text-black/40">{year}</p>
            <div>
              <h3 class="serif text-2xl">{title}</h3>
              <p class="mt-2 text-sm text-black/55">{detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-5 py-20 md:px-8">
    <div class="flex flex-col justify-between gap-8 md:flex-row md:items-end">
      <div>
        <p class="mb-5 text-xs uppercase tracking-[0.24em] text-black/45">
          Connect
        </p>

        <h2 class="serif max-w-3xl text-5xl leading-tight md:text-7xl">
          For exhibitions, collaborations, or artwork inquiries.
        </h2>
      </div>

      <a
        href="/en/contact"
        class="inline-flex bg-black px-8 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
      >
        Contact →
      </a>
    </div>
  </section>
</BaseLayout>