---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { site } from "../../data/site";
---

<BaseLayout
  lang="en"
  title="Contact PhanatchaNuch | Artwork Inquiry"
  description="Get in touch with PhanatchaNuch for artwork inquiries, collaborations, or exhibitions."
>
  <section class="mx-auto grid min-h-screen max-w-7xl gap-14 px-5 pb-24 pt-32 lg:grid-cols-[0.8fr_1.2fr] md:px-8">
    <div class="flex flex-col justify-between">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Contact
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          Interested in a piece?
        </h1>

        <p class="mt-8 max-w-md text-sm leading-8 text-black/65">
          Let’s connect and talk more about the work. For artwork inquiries,
          exhibitions, collaborations, or private viewing, send a message below.
        </p>
      </div>

      <div class="mt-14 grid gap-6 border-y border-black/10 py-8 text-sm sm:grid-cols-2">
        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Email</p>
          <p class="text-\[12px\] mt-3 text-black/70">{site.email}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Instagram</p>
          <p class="text-\[12px\] mt-3 text-black/70">@{site.instagram}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Location</p>
          <p class="text-\[12px\] mt-3 text-black/70">{site.location.en}</p>
        </div>

        <div>
          <p class="text-[11px] uppercase tracking-[0.2em] text-black/40">Response</p>
          <p class="text-\[12px\] mt-3 text-black/70">Usually within 24 hours</p>
        </div>
      </div>
    </div>

    <div class="bg-white p-6 md:p-10">
      <form id="contactForm" class="space-y-7">
        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Name
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="text"
            name="name"
            placeholder="Your name"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Email
          </label>
          <input
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            type="email"
            name="email"
            placeholder="your@email.com"
            required
          />
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Inquiry Type
          </label>
          <select
            class="mt-3 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="type"
          >
            <option value="artwork">Artwork inquiry</option>
            <option value="wall-painting">Wall painting project</option>
            <option value="exhibition">Exhibition</option>
            <option value="collaboration">Collaboration</option>
            <option value="private-viewing">Private viewing</option>
          </select>
        </div>

        <div>
          <label class="text-[11px] uppercase tracking-[0.2em] text-black/40">
            Message
          </label>
          <textarea
            class="mt-3 h-44 w-full border-b border-black/30 bg-transparent py-4 text-sm outline-none transition focus:border-black"
            name="message"
            placeholder="Tell me about the artwork or project you’re interested in..."
            required
          ></textarea>
        </div>

        <button
          class="flex w-full items-center justify-between bg-black px-7 py-4 text-xs uppercase tracking-[0.2em] text-white transition hover:bg-black/80"
          type="submit"
        >
          Send Message <span>→</span>
        </button>

        <div
          id="formMessage"
          class="hidden border border-black/10 bg-[#f7f7f4] p-5 text-sm leading-7 text-black/70"
        >
          Message sent successfully. This is a mockup form for preview.
        </div>

        <p class="text-\[12px\] leading-6 text-black/45">
          All inquiries are private. Prices are not displayed online and will be discussed personally.
        </p>
      </form>
    </div>
  </section>

  <script>
    const form = document.getElementById("contactForm");
    const message = document.getElementById("formMessage");

    const params = new URLSearchParams(window.location.search);
    const type = params.get("type");
    const artwork = params.get("artwork");
    const project = params.get("project");

    const typeSelect = form?.querySelector("select[name='type']");
    const messageInput = form?.querySelector("textarea[name='message']");

    if (typeSelect instanceof HTMLSelectElement && type) {
      typeSelect.value = type;
    }

    if (messageInput instanceof HTMLTextAreaElement) {
      if (artwork) {
        messageInput.value = `Hello, I am interested in the artwork: ${artwork}. Please share more details.`;
      }

      if (project) {
        messageInput.value = `Hello, I am interested in a wall painting project related to: ${project}. Please share more details.`;
      }

      if (type === "wall-painting" && !project) {
        messageInput.value =
          "Hello, I am interested in a custom wall painting project. I would like to discuss my space, idea, and timeline.";
      }
    }

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      form.reset();
      message?.classList.remove("hidden");
    });
  </script>
</BaseLayout>