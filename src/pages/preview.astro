---
import BaseLayout from "../layouts/BaseLayout.astro";

const pages = [
  {
    title: "Home",
    en: "/en",
    th: "/th",
    note: "Landing page / artist brand intro",
  },
  {
    title: "Gallery",
    en: "/en/gallery",
    th: "/th/gallery",
    note: "Artwork grid with mock filter",
  },
  {
    title: "Artwork Detail",
    en: "/en/artworks/fragments-of-rhythm-and-memory",
    th: "/th/artworks/fragments-of-rhythm-and-memory",
    note: "Artwork detail with inquiry CTA and lightbox",
  },
  {
    title: "Exhibitions",
    en: "/en/exhibitions",
    th: "/th/exhibitions",
    note: "Current exhibition presentation",
  },
  {
    title: "Profile",
    en: "/en/profile",
    th: "/th/profile",
    note: "Artist profile and statement",
  },
  {
    title: "Contact",
    en: "/en/contact",
    th: "/th/contact",
    note: "Mock contact form",
  },
];
---

<BaseLayout
  lang="en"
  title="Client Preview | PhanatchaNuch"
  description="Preview all mockup pages for PhanatchaNuch art gallery website."
>
  <section class="mx-auto max-w-7xl px-5 pb-24 pt-32 md:px-8">
    <div class="mb-16 grid gap-8 md:grid-cols-[0.8fr_1.2fr] md:items-end">
      <div>
        <p class="mb-6 text-xs uppercase tracking-[0.24em] text-black/45">
          Client Preview
        </p>

        <h1 class="serif text-6xl leading-[0.95] md:text-8xl">
          Website Mockup
        </h1>
      </div>

      <p class="max-w-lg text-sm leading-8 text-black/60 md:justify-self-end">
        This page collects all key screens for client review. The website is currently
        a frontend mockup with responsive layout, bilingual content, SEO structure,
        gallery filter, artwork lightbox, and mock contact form.
      </p>
    </div>

    <div class="grid gap-6">
      {pages.map((page, index) => (
        <div class="grid gap-6 border-t border-black/10 py-8 md:grid-cols-[80px_1fr_1fr] md:items-center">
          <p class="text-xs uppercase tracking-[0.2em] text-black/35">
            {String(index + 1).padStart(2, "0")}
          </p>

          <div>
            <h2 class="serif text-4xl">{page.title}</h2>
            <p class="mt-2 text-sm text-black/55">{page.note}</p>
          </div>

          <div class="flex flex-wrap gap-3 md:justify-end">
            <a
              href={page.en}
              class="border border-black px-5 py-3 text-xs uppercase tracking-[0.18em] hover:bg-black hover:text-white"
            >
              View EN →
            </a>

            <a
              href={page.th}
              class="border border-black/20 px-5 py-3 text-xs uppercase tracking-[0.18em] hover:border-black"
            >
              View TH →
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>